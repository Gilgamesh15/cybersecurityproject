    }
    lineNumbersContainer.style.visibility = "visible";
  });
})()</script></div></div></div></div></div></div></div></div><div class="hidden" data-testid="ssr-tab-content"><div><h5>npm</h5><pre><code class="language-bash">npm i -g @shopify/cli@latest</code></pre></div><div><h5>yarn</h5><pre><code class="language-bash">yarn global add @shopify/cli@latest</code></pre></div><div><h5>pnpm</h5><pre><code class="language-bash">pnpm add -g @shopify/cli@latest</code></pre></div></div></div><div aria-hidden="false" data-testid="controlled-item-apps"><div class="_Card_q9ijc_1 _DefaultCard_q9ijc_11 Theme-Docs Mode-Dim _CodeBlockContainer_vneml_1 CodeBlockContainerHeight _MdxCodeblock_ebwmn_1"><header class="_CardHeader_q9ijc_107"><div class="_TitleBar_1vdkz_1"><h2 class="_Heading_1vdkz_20"><svg width="16" height="16" class="_Icon_1vdkz_37" aria-hidden="true"><use href="#TerminalSmall"></use></svg>Initialize your app instance</h2></div><div class="_CardActionBar_q9ijc_38"><span aria-describedby="_R_9ajcm75_" data-state="closed"><button type="button" class="_CardActionButton_q9ijc_47 _CodeBlockActionButton_vneml_21"><svg width="20" height="20" class="_CodeBlockActionIcon_vneml_17" aria-hidden="true"><use href="#CopyMedium"></use></svg><span class="_CardActionButtonLabel_q9ijc_79">Copy</span></button></span></div></header><div class="_CodeBlockContent_vneml_34"><div data-language="bash" class="_Editor_1kljl_1" style="--gutter-padding:var(--size-100)"><div><style>
