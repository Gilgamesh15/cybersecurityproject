      const lineNumber = lineNumbers2[index2];
      lineNumber.style.height = `${lineBox.height}px`;
    }
    lineNumbersContainer.style.visibility = "visible";
  });
})()</script></div></div></div></div></div><div data-state="inactive" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-_R_66jcm75_-trigger-tab-1" id="radix-_R_66jcm75_-content-tab-1" tabindex="0" class="_CardTabsContentInner_q9ijc_282"><div data-markdown="remove" class="_TabContentWrapper_vneml_57"><div class="_CodeBlockContent_vneml_34 _CodeBlockMaxHeight_vneml_49"><div data-language="bash" class="_Editor_1kljl_1" style="--gutter-padding:var(--size-100)"><div><style>
