  const container2 = document.currentScript.parentElement;
  requestAnimationFrame(() => {
    if (!container2.isConnected) return;
    const lineNumbersContainer = container2.querySelector(
      ".cm-lineNumbers"
    );
    const guttersContainer = container2.querySelector(
      ".cm-gutters"
    );
    if (!guttersContainer || !lineNumbersContainer) return;
    guttersContainer.style.minHeight = "0px";
    const lineNumbers2 = [
      ...container2.querySelectorAll(".cm-lineNumbers .cm-gutterElement")
    ].slice(1);
    const lines = [...container2.querySelectorAll(".cm-content .cm-line")];
    const lineBoxes = lines.map((line) => line.getBoundingClientRect());
    for (const [index2, lineBox] of lineBoxes.entries()) {
      const lineNumber = lineNumbers2[index2];
      lineNumber.style.height = `${lineBox.height}px`;
    }
    lineNumbersContainer.style.visibility = "visible";
  });
})()</script></div></div></div></div></div><div class="_ControlledItemHidden_10gi2_68 visuallyHidden" aria-hidden="true" data-testid="controlled-item-headless"><div class="_Card_q9ijc_1 _DefaultCard_q9ijc_11 Theme-Docs Mode-Dim _CodeBlockContainer_vneml_1 CodeBlockContainerHeight _MdxCodeblock_ebwmn_1"><header class="_CardHeader_q9ijc_107"><div class="_TitleBar_1vdkz_1"><h2 class="_Heading_1vdkz_20"><svg width="16" height="16" class="_Icon_1vdkz_37" aria-hidden="true"><use href="#TerminalSmall"></use></svg>Initialize your storefront instance</h2></div><div class="_CardActionBar_q9ijc_38"><span aria-describedby="_R_9ijcm75_" data-state="closed"><button type="button" class="_CardActionButton_q9ijc_47 _CodeBlockActionButton_vneml_21"><svg width="20" height="20" class="_CodeBlockActionIcon_vneml_17" aria-hidden="true"><use href="#CopyMedium"></use></svg><span class="_CardActionButtonLabel_q9ijc_79">Copy</span></button></span></div></header><div class="_CodeBlockContent_vneml_34"><div data-language="bash" class="_Editor_1kljl_1" style="--gutter-padding:var(--size-100)"><div><style>
