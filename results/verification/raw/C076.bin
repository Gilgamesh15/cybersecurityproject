<script>
  const SOPHI_HOST_BY_GEO = {
    AU: '263596202',
    GB: '3666695123',
    ROW: '1925013842',
    US: '1321371076'
  };

  const SOPHI_HOST_BY_GEO_INT = {
    AU: '2351856024',
    GB: '711919013',
    ROW: '434186525',
    US: '454933469'
  };

  const PAYWALL_EXCLUDE_GEOS = ['IN', 'IR', 'CU', 'KP', 'SY', 'VE', 'AF', 'BY', 'BI', 'CF', 'CN', 'HK', 'CD', 'EG', 'ER', 'ET', 'IQ', 'LB', 'LY', 'ML', 'MM', 'NI', 'GN', 'GW', 'RU', 'SO', 'SS', 'SD', 'TN', 'TR', 'UA', 'YE', 'ZW'];

  window.getIsPaywallEligible = () => {
   return window.PageCriteria && window.PageCriteria.geo && !PAYWALL_EXCLUDE_GEOS.includes(window.PageCriteria.geo);
  };

  const getSophiGeo = () => {
    const geo = window?.PageCriteria?.cljGeo || 'GB';

    if (['GB', 'IE'].includes(geo)) {
      return 'GB';
    }

    if (['AU', 'NZ'].includes(geo)) {
      return 'AU';
    }

    if (['US', 'CA', 'MX'].includes(geo)) {
      return 'US';
    }

    return 'ROW';
  };

  const scriptPromises = new Map();

  const addSophiScriptToPage = (hostId) => {
    const source = `https://cdn.sophi.io/assets/demeter/1/stable/${hostId}.js`;

    if (scriptPromises.has(source)) {
      return scriptPromises.get(source);
    }

    const script = document.createElement('script');

    script.id = 'sophi-loader';
    script.async = true;
    script.fetchPriority = 'high';

    const promise = new Promise((resolve, reject) => {
      script.src = source;

      script.onload = () => resolve(true);

      script.onerror = () => {
        if (!window.molSophiFeatureOff) {
          window.molSophiFeatureOff = 'sophi-script-load-error';
        }

        console.error(`*** Failed to load script: ${script.src}`);

        window._s('xsl');

        reject(new Error(`Failed to load script: ${script.src}`));
      };

      document.head.appendChild(script);

      window._s('l');
    });

    scriptPromises.set(source, promise);

    return promise;
  };

  const setSophiHelper = () => {
    window._s = function (condition) {
      const demeter = window.sophi.demeter;
      const formatTime = String(Math.floor(performance.now() / 10) / 100).replace(/^0\./, '.');

      demeter.initStatus = `${demeter.initStatus ? `${demeter.initStatus},` : ''}${condition}${formatTime}`;
    };
  };

  const loadSophiScript = async () => {
    window.sophi = window.sophi || {};

    window.sophi.demeter = {
      actions: [],
      initStatus: ''
    };

    setSophiHelper();

    window.demeter = window.demeter ||
      async function () {
        let resolve;
        let reject;

        const task = new Promise((_resolve, _reject) => {
          resolve = _resolve;
          reject = _reject;
        });

        window.sophi.demeter.actions.push([arguments, resolve, reject]);

        window._s('i');

        return task;
      };

    window.addEventListener(
      'sophiDataLayerReady',
      (event) => {
        window.molSophiDataLayerEventFired = event;
      },
      { once: true }
    );

    const hostIds = window?.location.hostname.includes('int')
      ? SOPHI_HOST_BY_GEO_INT
      : SOPHI_HOST_BY_GEO;

    const hostId = hostIds[getSophiGeo()];

    await addSophiScriptToPage(hostId);
  };

  loadSophiScript().catch((error) => {
    console.error('Error loading Sophi script inline', error);
  });
</script>
