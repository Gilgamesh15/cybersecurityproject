                                    <div class="fcs-slider-card__body">
                                        <div class="fcs-slider-card__media">
                                            <svg class="fcs-icon fcs-icon--slider icon-sprite" aria-hidden="true"><use xlink:href="/images/fcs-sprite.svg?v=sciNIYbFtd_VlYrotnkZ2MUKXAvtdmoN7cumjZOat3Q#fcs-icon-piggy-bank"></use></svg>
                                        </div>
                                        <strong class="fcs-slider-card__title">
                                            Student loan assistance
                                        </strong>
                                    </div>
