//California only
function OptanonWrapper(){
    if (OneTrust.getGeolocationData().state.toUpperCase() == "CA"){
        //setup DNSS version of modal    
        window.doNotShareUI = function() {
            document.querySelector("#ot-pc-title").style.display = "none";
            document.querySelector(".ot-optout-signal").style.display = "none";
            document.querySelector("#ot-category-title").style.display = "none";
            document.querySelector("#ot-pc-desc").innerHTML = "<p style='margin-top: 1.5rem;'><strong>Fidelity does not sell your information to third parties for monetary consideration.</strong> However, we and our marketing and advertising providers (providers) do collect and store certain information (information) about you, including through the use of cookies and similar means (cookies) stored on your device when you visit our site. We and our providers use this information to personalize your browsing experience on our site and to deliver ads about Fidelity products, features, or promotional offerings tailored to your interests on other sites that you visit.</p><p>This sharing of your information with third parties via cookies, and our providers' use of cookies, may be considered a \"sale\" of personal information or \"sharing\" of personal information under California laws.  We do not share your information with our providers via cookies unless you opt-in to such sharing. To opt-in, switch the \"Sale or Sharing of Personal Information\" toggle below to <strong>on</strong> by moving it to the right. This opt-in is a setting that is specific to the device or browser you're using. You'll need to opt in again if you visit our site from a different device or browser, change your browser settings, or clear your cookies. You may opt out of this information sharing at any time by switching the toggle below back to <strong>off</strong>.</p><p>You can learn more about our personal information handling practices and your rights by visiting our <a href='https://jobs.fidelity.com/media/2m2o4iky/fidelity-global-applicant-privacy-notice_2024-final.pdf' target='_blank'>Privacy Policy</a>.</p>";

            document.querySelectorAll(".ot-sdk-row .ot-vs-config").forEach((otCategory) => {
                        if (otCategory.dataset.optanongroupid == "C0004"){
                            document.querySelector("#ot-header-id-C0004").innerText = "Sale or Sharing of Personal Information";
                            document.querySelector("[data-optanongroupid=C0004] .ot-plus-minus").style.display = "none";
                            document.querySelector("[data-optanongroupid=C0004] .ot-acc-grpcntr").style.display = "none";
                        }
                        else {
                            otCategory.style.display = "none";
                        }
                    });
        }
        //reset default version of modal
        window.hideDnsUI = function() {
            document.querySelectorAll(".ot-sdk-row .ot-vs-config").forEach((otCategory) => {
                otCategory.style.display = "block";
            });

            document.querySelector("#ot-pc-title").style.display = "block";
            document.querySelector(".ot-optout-signal").style.display = "block";
            document.querySelector("#ot-category-title").style.display = "block";
            document.querySelector("#ot-pc-desc").innerHTML = "<p>When you visit our website, it may store or retrieve information on your browser, mostly in the form of cookies. Because we respect your right to privacy, you can choose not to allow some types of cookies. Click on the different category headings to find out more and change our default settings. However, blocking some types of cookies may impact your experience on this site and the services we are able to offer.</p><p><a href='https://jobs.fidelity.com/media/2m2o4iky/fidelity-global-applicant-privacy-notice_2024-final.pdf' class='privacy-notice-link' rel='noopener' target='_blank' aria-label='More information about your privacy, opens in a new tab'>Review Privacy Policy</a></p>";

            document.querySelector("#ot-header-id-C0004").innerText = "Targeting or Advertising Cookies";
            document.querySelector("[data-optanongroupid=C0004] .ot-plus-minus").style.display = "block";
            document.querySelector("[data-optanongroupid=C0004] .ot-acc-grpcntr").style.display = "block";
        }

        setTimeout(function() {
            document.querySelector(".ot-sdk-show-settings").addEventListener("click", doNotShareUI);
            document.querySelector(".ot-floating-button__open").addEventListener("click", hideDnsUI);
            document.getElementById("ot-sdk-btn-floating").dataset.title = "Manage my tracking/advertising cookies";
        }, 2500);
    }
}

</script>
<style>
#accept-recommended-btn-handler { display: none !important; }
</style><style>
html[lang=en-IN] .fcs-footer-nav__social .tiktok { display: none; }
</style><script>
if (document.querySelector(".fcs-explore-card__quote p") != null){
    document.querySelector(".fcs-explore-card__quote p").innerHTML = document.querySelector(".fcs-explore-card__quote p").innerText;
}
</script><style>
@media (min-width: 992px) {
    html[lang=en-IN] .fcs-explore .fcs-explore-card, html[lang=en-IE] .fcs-explore .fcs-explore-card {
        flex: calc(33.333333% - 26.6666666667px) 0 0 !important;
    }
}
@media (min-width: 768px) {
    html[lang=en-IN] .fcs-explore-card--feat .fcs-explore-card__copy, html[lang=en-IE] .fcs-explore-card--feat .fcs-explore-card__copy {
        width: 100%;
    }
    html[lang=en-IN] .fcs-explore-card--feat, html[lang=en-IE] .fcs-explore-card--feat {
        grid-template-columns: 1fr;
    }
}
</style><script>
document.querySelectorAll("a").forEach((link) => {
    if (link.href.indexOf("pages.beamery.com") > -1){
        link.href = link.href.replace("pages.beamery.com", "talentcommunity.fidelity.com").replace("/fidelity/", "/portal/");
    }
});
</script><style>
@media (min-width: 1200px){
    .fcs-4up__highlights {
        grid-template-columns: repeat(auto-fit, minmax(0, 1fr)) !important;
    }
}
</style><script>
document.querySelectorAll(".js-view-all-posts").forEach(link => {
    link.classList.add("fcs-btn");
    link.classList.add("fcs-btn--outline");
});

if (document.querySelector(".fcs-feat-stories__body .view-all") != null){
    let viewLink = document.querySelector(".fcs-feat-stories__body .view-all");
    viewLink.style.padding = "2rem 0";
    document.querySelector(".fcs-feat-stories__list").insertAdjacentElement("afterEnd", viewLink);
    
    document.querySelector(".view-all a").href += "life-at-fidelity/our-stories/";
}
</script><style>
.fcs-faq-accordion .fcs-simple-text__copy {
    text-align: left;
    margin-bottom: 2rem;
}
.fcs-faq-accordion-item__body {
    border-top-color: #6AD539;
}
</style><style>
.img-link:hover img {
    transform: scale(1) !important;
}
.fcs-article {
        margin-top: 2rem !important;
        margin-bottom: 2rem !important;
    }
</style><style>
.tagline {
    float: left;
    color: #fff;
    line-height: 2rem;
    font-size: 0.75rem;
    pointer-events: none;
}
</style>
<script>
let lang = document.querySelector("html").getAttribute("lang");
let tagline = "";

if (lang == "en-IE"){
    tagline = "<p class='tagline'>Fidelity Investments in Ireland</p>";
}
else if (lang == "en-IN"){
    tagline = "<p class='tagline'>Fidelity Investments in India</p>";
}

document.querySelector(".fcs-nav__utility").insertAdjacentHTML("afterBegin",tagline);
</script><style>
.fcs-article--intro__copy p {
    margin-bottom: 1.5rem;
}
</style><style>
.more-block {
    break-inside: avoid;
}
</style><script>
//make cards in slider accessible to tab order
document.querySelectorAll(".fcs-slider-card").forEach(card => {
    card.setAttribute("tabindex", "0");
});
//set ARIA role for accordion bodies
document.querySelectorAll(".fcs-location__body, .fcs-faq-accordion-item__body").forEach(accordion => {
    accordion.setAttribute("role", "region");
});
</script>

    
    

</body>
</html>



