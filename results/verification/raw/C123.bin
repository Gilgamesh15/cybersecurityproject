                            <div class="fcs-card-list-item__content">
                                <h3 class="fcs-card-list-item__title">
                                    Business operations
                                </h3>
                                <div class="fcs-card-list-item__copy"><p>Support our business through communications, risk management, finance, and human resource roles.</p></div>
                            </div>
                            <a class="fcs-card-list-item__button fcs-btn fcs-btn--outline js-team-link js-team-1767 js-cta-link" href="/en/teams/business-operations/" data-type="teams_block">
