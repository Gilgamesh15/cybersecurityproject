<!DOCTYPE html>
<html lang="en-US" prefix="og: http://ogp.me/ns#">

<head itemscope itemtype="http://schema.org/Article">
  <meta charset="UTF-8"/>
  <meta content="IE=EDGE" http-equiv="X-UA-Compatible"/>
  <meta
      content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, user-scalable=no"
      name="viewport">
  <style type="text/css">
    .content_margin_404page {
      margin-left: 17px;
      margin-top: 22px;
    }

    .content_margin_404page p a {
      color: #F96302;
    }

    .line1_404page {
      margin-top: 5px;
      margin-bottom: 20px;
    }

    .buttons_margin_404page {
      margin-top: 25px;
    }

    #lnReturnHomepage {
      margin-right: 15px;
    }

    .customercare_404page {
      float: left;
      padding-bottom: 20px;
      margin-top: 45px;
    }

  </style>
</head>

<body>

<!--Content -->
<div class="grid isBound">
  <div class="col__12-12">
    <div class="content_margin_404page">
      <div class="content">
        <p class="line1_404page">This could be due to one of the following reasons:</p>
        <p>An internal homedepot.com error occurred.<br/>
          The file or page you are looking for no longer exists.<br/>
          The URL that was typed is incorrect.</p>
        <div class="buttons_margin_404page">
          <a class="btn btn-orange" href="http://www.homedepot.com" id="lnReturnHomepage"><span
              class="icon-carrot-white">return to homepage</span></a>

          <a class="btn " href="http://www.homedepot.com/site-directory/index.html"
             id="lnExploreSiteMap"><span
              class="icon-carrot-grey">Explore site map</span></a>
        </div>
        <br class="clear"/>
        <div class="customercare_404page">
          <p>If you have any questions, you can reach our web support team by email at <a
              href="mailto:customercare@homedepot.com">customercare@homedepot.com</a> or by phone at
            1-800-430-3376.</p></div>


      </div>
    </div>
    <!--Content Goes Here!-->
  </div>
</div>
<!--Home Depot Include -->
<!-- Old On-Prem Version
<<script id="THDHeaderFooter" hfapp-callertype="error-page" channel="web" bootstrap="false" src="http://homedepot.com/HFApp/static/include/thirdparty/thd.include.third_party.js"></script -->
<script bootstrap="false" channel="web" hfapp-callertype="error-page" hfapp-version="6.1"
        id="THDHeaderFooter"
        src="https://www.homedepot.com/hf/thirdparty/js/thd.include.third_party.js"></script>

</body>

</html>
